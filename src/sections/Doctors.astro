---
import SectionTitle from "@/components/SectionTitle.astro";
import { doctors } from "@/content/doctors";
---

<section class="section-pad bg-shell">
  <div class="container-page">
    <SectionTitle
      eyebrow="La Doctora"
      title="Profesional comprometida con tu salud oral y bienestar."
      intro="Formación clínica, sensibilidad estética y trato cercano. Cada consulta es una oportunidad para conocer tus necesidades y diseñar el mejor camino para tu sonrisa."
      align="center"
    />
    <div class="mt-10 flex justify-center">
      {doctors.map((doctor) => (
        <article class="rounded-lg bg-white p-4 shadow-soft max-w-sm w-full">
          <img class="aspect-[4/5] w-full rounded-md object-cover" src={doctor.image} alt={`Foto de ${doctor.name}`} loading="lazy" />
          <div class="p-3">
            <h3 class="font-display text-2xl font-semibold text-ink">{doctor.name}</h3>
            <p class="mt-1 text-sm font-semibold text-sage">{doctor.role}</p>
            <p class="mt-3 text-sm leading-6 text-cocoa">{doctor.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
