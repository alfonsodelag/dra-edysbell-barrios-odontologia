---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import Contact from "@/sections/Contact.astro";
import BacPromotion from "@/sections/BacPromotion.astro";
import { servicesByCategory, categories } from "@/content/services";
---

<BaseLayout
  title="Servicios odontológicos | Dra. Edysbell Barrios Odontóloga"
  description="Diseño de sonrisa, blanqueamiento dental, limpieza profesional, carillas, restauraciones, cirugías, ortodoncia y armonización orofacial en Panamá con la Dra. Edysbell Barrios."
>
  <!-- Encabezado -->
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="Servicios"
        title="Tratamientos dentales para cuidar tu salud oral y realzar tu sonrisa."
        intro="Cada tratamiento parte de una evaluación personalizada. Aquí encontrarás todas las áreas de atención de la Dra. Edysbell Barrios en odontología estética y salud oral."
        align="center"
      />

      <!-- Navegación por categoría -->
      <div class="mt-10 flex flex-wrap justify-center gap-2">
        {categories.map((cat) => (
          <a
            href={`#${cat.toLowerCase().replace(/\s+/g, "-").replace(/[áéíóú]/g, (c: string) => ({á:"a",é:"e",í:"i",ó:"o",ú:"u"})[c] ?? c)}`}
            class="rounded-full border border-ink/15 bg-cream px-4 py-1.5 text-xs font-semibold text-ink transition hover:border-sage hover:text-sage"
          >
            {cat}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Servicios por categoría -->
  {categories.map((cat, i) => {
    const catServices = servicesByCategory[cat] ?? [];
    const anchorId = cat.toLowerCase().replace(/\s+/g, "-").replace(/[áéíóú]/g, (c: string) => ({á:"a",é:"e",í:"i",ó:"o",ú:"u"})[c] ?? c);
    return (
      <section id={anchorId} class={`section-pad ${i % 2 === 0 ? "bg-cream" : "bg-white"}`}>
        <div class="container-page">
          <span class="eyebrow">{cat}</span>
          <h2 class="mt-2 font-display text-2xl font-semibold text-ink">{cat}</h2>
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {catServices.map((service) => (
              <article class="card group overflow-hidden transition hover:-translate-y-1">
                <div class="relative overflow-hidden">
                  <img
                    class="h-48 w-full object-cover transition duration-300 group-hover:scale-105"
                    src={service.image}
                    alt={`${service.title} — Dra. Edysbell Barrios`}
                    loading="lazy"
                  />
                  {service.bacEligible && (
                    <span class="absolute right-3 top-3 rounded-full bg-ink px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wide text-white">
                      BAC 3 cuotas
                    </span>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="font-display text-lg font-semibold text-ink">{service.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-cocoa line-clamp-2">{service.description}</p>
                  <a
                    class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-sage hover:text-ink transition-colors"
                    href={`/services/${service.slug}`}
                  >
                    Ver detalles
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <BacPromotion />
  <Contact />
</BaseLayout>
