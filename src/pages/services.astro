---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import Contact from "@/sections/Contact.astro";
import { services } from "@/content/services";
---

<BaseLayout
  title="Servicios odontológicos | Dra. Edysbell Barrios Odontóloga"
  description="Diseño de sonrisa, blanqueamiento dental, limpieza profesional, carillas, restauraciones, bruxismo y armonización orofacial en Panamá con la Dra. Edysbell Barrios."
>
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="Servicios"
        title="Tratamientos dentales para cuidar tu salud oral y realzar tu sonrisa."
        intro="Cada tratamiento parte de una evaluación personalizada. Aquí encontrarás las principales áreas de atención de la Dra. Edysbell Barrios en odontología estética y salud oral."
        align="center"
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <article class="card overflow-hidden">
            <img class="h-52 w-full object-cover" src={service.image} alt={service.title} loading="lazy" />
            <div class="p-6">
              <h2 class="font-display text-2xl font-semibold text-ink">{service.title}</h2>
              <p class="mt-3 text-sm leading-6 text-cocoa">{service.description}</p>
              <a class="mt-5 inline-flex text-sm font-semibold text-sage hover:text-ink" href="/contact">Consultar disponibilidad</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  <Contact />
</BaseLayout>
